{
  "$schema": "https://unpkg.com/knip@5/schema.json",
  "entry": ["__tests__/**/*.test.ts", "prisma/**/*.ts"],
  "project": ["src/**/*.{ts,tsx}", "__tests__/**/*.ts", "prisma/**/*.ts"],
  "ignore": ["src/components/ui/**", "src/hooks/use-mobile.tsx"],
  "ignoreDependencies": [
    "pg",
    "@fontsource-variable/geist",
    "@fontsource/fraunces",
    "shadcn",
    "tw-animate-css",
    "tailwindcss"
  ],
  "paths": {
    "@/*": ["./src/*"]
  },
  "rules": {
    "duplicates": "off"
  }
}
