generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

generator erd {
  provider     = "prisma-erd-generator"
  output       = "./ERD.md"
  theme        = "neutral"
  disableEmoji = true
}

datasource db {
  provider = "postgresql"
}

enum ScenarioStatus {
  draft
  generating
  completed
  failed
}

enum ChapterStatus {
  draft
  generating
  completed
}

enum CueKind {
  speech
  pause
}

model Character {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  name            String
  imageUrl        String?  @map("image_url")
  ageGroup        String   @default("young_adult") @map("age_group")
  gender          String   @default("male")
  occupation      String   @default("student_high")
  personalityTags String[] @map("personality_tags")
  speechStyle     String   @default("neutral") @map("speech_style")
  firstPerson     String   @default("boku") @map("first_person")
  secondPerson    String   @default("") @map("second_person")
  honorific       String   @default("san")
  attributeTags   String[] @map("attribute_tags")
  backgroundTags  String[] @map("background_tags")
  memo            String   @default("")
  speakerId       String?  @map("speaker_id")

  speaker Speaker? @relation(fields: [speakerId], references: [id], onDelete: SetNull)

  relationsFrom CharacterRelation[]        @relation("RelationFrom")
  relationsTo   CharacterRelation[]        @relation("RelationTo")
  narratorOf    Scenario[]                 @relation("Narrator")
  scenarioCasts ScenarioCast[]
  chapterLinks  ScenarioChapterCharacter[]

  @@index([speakerId])
  @@map("characters")
}

model Speaker {
  id        String   @id
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  name String

  characters Character[]

  @@map("speakers")
}

model CharacterRelation {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  fromCharacterId String @map("from_character_id")
  toCharacterId   String @map("to_character_id")
  relationType    String @map("relation_type")

  fromCharacter Character @relation("RelationFrom", fields: [fromCharacterId], references: [id], onDelete: Cascade)
  toCharacter   Character @relation("RelationTo", fields: [toCharacterId], references: [id], onDelete: Cascade)

  @@unique([fromCharacterId, toCharacterId])
  @@map("character_relations")
}

model Scenario {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  title   String
  genres  String[]
  tone    String
  ending  String
  status  ScenarioStatus @default(draft)
  vdsJson Json?          @map("vds_json")

  narratorId String?    @map("narrator_id")
  narrator   Character? @relation("Narrator", fields: [narratorId], references: [id], onDelete: SetNull)

  cast     ScenarioCast[]
  chapters ScenarioChapter[]

  @@map("scenarios")
}

model ScenarioCast {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now()) @map("created_at")

  scenarioId   String @map("scenario_id")
  characterId  String @map("character_id")
  role         String
  relationship String
  alias        String

  scenario  Scenario  @relation(fields: [scenarioId], references: [id], onDelete: Cascade)
  character Character @relation(fields: [characterId], references: [id], onDelete: Cascade)

  @@unique([scenarioId, characterId])
  @@unique([scenarioId, alias])
  @@map("scenario_casts")
}

model ScenarioChapter {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  scenarioId      String        @map("scenario_id")
  number          Int
  title           String
  status          ChapterStatus @default(draft)
  cueCount        Int           @default(0) @map("cue_count")
  durationMinutes Float         @default(0) @map("duration_minutes")
  synopsis        String        @default("")

  scenario   Scenario                   @relation(fields: [scenarioId], references: [id], onDelete: Cascade)
  cues       ScenarioCue[]
  characters ScenarioChapterCharacter[]

  @@unique([scenarioId, number])
  @@map("scenario_chapters")
}

model ScenarioChapterCharacter {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now()) @map("created_at")

  chapterId   String @map("chapter_id")
  characterId String @map("character_id")

  chapter   ScenarioChapter @relation(fields: [chapterId], references: [id], onDelete: Cascade)
  character Character       @relation(fields: [characterId], references: [id], onDelete: Cascade)

  @@unique([chapterId, characterId])
  @@map("scenario_chapter_characters")
}

model ScenarioCue {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  chapterId     String  @map("chapter_id")
  order         Int     @map("cue_order")
  kind          CueKind
  speakerAlias  String? @map("speaker_alias")
  text          String?
  pauseDuration Float?  @map("pause_duration")
  synthOptions  Json?   @map("synth_options")

  chapter ScenarioChapter @relation(fields: [chapterId], references: [id], onDelete: Cascade)

  @@unique([chapterId, order])
  @@index([chapterId])
  @@map("scenario_cues")
}
